%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor': '#00D4FF', 'primaryTextColor': '#fff', 'lineColor': '#00D4FF'}}}%%

flowchart TB
    subgraph PROMPTS["PROMPTS (AI Direction)"]
        direction TB
        SYS["system_prompt.py<br/>SA Electrical Domain Knowledge<br/>SANS 10142-1 rules<br/>NRS 034 ADMD values"]

        subgraph TIER_PROMPTS["Tier-Specific Prompts"]
            RES["residential_prompts.py<br/>Room-by-room schema"]
            COM["commercial_prompts.py<br/>Area-based W/m2"]
            MAIN["maintenance_prompts.py<br/>COC defect codes"]
        end

        subgraph PASS_PROMPTS["Multi-Pass Prompts"]
            P1["sld_prompt.py<br/>Circuit schedules"]
            P2["lighting_layout.py<br/>Fixture counting"]
            P3["plugs_layout.py<br/>Socket counting"]
            P4["legend_prompt.py<br/>Symbol definitions"]
        end
    end

    subgraph AI["AI MODELS (Extraction)"]
        HAIKU["Haiku 4.5<br/>Fast Classification<br/>~R0.18"]
        SONNET["Sonnet 4.5<br/>Multi-Pass Extraction<br/>~R1.80"]
        OPUS["Opus 4.6<br/>Escalation Only<br/>~R8.50"]
    end

    subgraph CODE["CODE (Deterministic Logic)"]
        direction TB

        subgraph UTILS["utils/"]
            CALC["calculations.py<br/>SANS formulas<br/>load, voltage drop, ADMD"]
            CONST["constants.py<br/>SA Material Database<br/>1650 lines of prices"]
        end

        subgraph STAGES["agent/stages/"]
            VAL["validate.py<br/>SANS 10142-1 Rules<br/>Auto-corrections"]
            PRICE["price.py<br/>14-Section BOQ<br/>Dual BQ generation"]
        end
    end

    subgraph OUTPUT["FINAL OUTPUT"]
        PDF["PDF Quotation<br/>Professional format<br/>Brand colors"]
        EXCEL["Excel BOQ<br/>4 Sheets:<br/>Cover | BOQ | Summary | Discrepancy"]
        JSON_OUT["JSON Results<br/>Full pipeline data<br/>Confidence scores"]
    end

    %% Prompt flows
    SYS --> HAIKU
    SYS --> SONNET
    RES --> SONNET
    COM --> SONNET
    MAIN --> SONNET
    P1 --> SONNET
    P2 --> SONNET
    P3 --> SONNET
    P4 --> SONNET

    %% AI to extraction
    HAIKU -->|"ServiceTier"| SONNET
    SONNET -->|"ExtractionResult"| VAL
    SONNET -.->|"confidence < 70%"| OPUS
    OPUS -.->|"Re-extract"| VAL

    %% Code processing
    VAL -->|"Validated data"| PRICE
    CALC --> PRICE
    CONST --> PRICE

    %% Output generation
    PRICE --> PDF
    PRICE --> EXCEL
    PRICE --> JSON_OUT

    %% Styling
    style SYS fill:#9b59b6,stroke:#9b59b6,color:#fff
    style RES fill:#8e44ad,stroke:#8e44ad,color:#fff
    style COM fill:#8e44ad,stroke:#8e44ad,color:#fff
    style MAIN fill:#8e44ad,stroke:#8e44ad,color:#fff
    style HAIKU fill:#3498db,stroke:#3498db,color:#fff
    style SONNET fill:#2980b9,stroke:#2980b9,color:#fff
    style OPUS fill:#1a5276,stroke:#1a5276,color:#fff
    style VAL fill:#27ae60,stroke:#27ae60,color:#fff
    style PRICE fill:#f39c12,stroke:#f39c12,color:#000
    style CALC fill:#2ecc71,stroke:#2ecc71,color:#000
    style CONST fill:#e67e22,stroke:#e67e22,color:#000
    style PDF fill:#00D4FF,stroke:#00D4FF,color:#000
    style EXCEL fill:#00D4FF,stroke:#00D4FF,color:#000
    style JSON_OUT fill:#00D4FF,stroke:#00D4FF,color:#000

    classDef promptBox fill:#9b59b6,stroke:#9b59b6,color:#fff
    classDef aiBox fill:#3498db,stroke:#3498db,color:#fff
    classDef codeBox fill:#27ae60,stroke:#27ae60,color:#fff
    classDef outputBox fill:#00D4FF,stroke:#00D4FF,color:#000
