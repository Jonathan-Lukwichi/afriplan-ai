%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor': '#00D4FF', 'secondaryColor': '#4A148C', 'tertiaryColor': '#1a1a2e'}}}%%

flowchart TB
    subgraph INPUT["USER INPUT"]
        PDF1[Cover Page PDF]
        PDF2[SLD PDF]
        PDF3[Lighting Layout PDF]
        PDF4[Power Layout PDF]
        IMG[Image Files]
    end

    subgraph INGEST["STAGE 1: INGEST<br/>(PyMuPDF + Pillow - FREE)"]
        direction LR
        I1[PDF to Images<br/>150 DPI]
        I2[Image Enhancement]
        I3[OCR Text Extract]
        I4[Page Classification]
        I1 --> I2 --> I3 --> I4
    end

    subgraph PROMPTS_CLASSIFY["PROMPTS"]
        PC["classify_prompt.py<br/>Tier keywords"]
    end

    subgraph CLASSIFY["STAGE 2: CLASSIFY<br/>(AI: Haiku/Groq ~R0.18)"]
        C1["Analyze document type"]
        C2{Tier?}
        C1 --> C2
        C2 -->|Residential| R[RESIDENTIAL]
        C2 -->|Commercial| COM[COMMERCIAL]
        C2 -->|Maintenance| M[MAINTENANCE]
    end

    subgraph SYSTEM_PROMPT["SYSTEM PROMPT<br/>(SA Electrical Domain)"]
        SP1["SANS 10142-1:2017 Rules"]
        SP2["NRS 034 ADMD Values"]
        SP3["Max 10 points/circuit"]
        SP4["SA Cable Standards"]
        SP5["Load Calculations"]
    end

    subgraph DISCOVER["STAGE 3: DISCOVER<br/>(AI: Sonnet/Llama4 ~R1.80)"]
        direction TB
        D1["Pass 1: PROJECT_INFO<br/>Project name, client, date"]
        D2["Pass 2: DB_DETECTION<br/>Find ALL Distribution Boards"]
        D3["Pass 3: DB_SCHEDULES<br/>Circuits per DB (MCB, cable, points)"]
        D4["Pass 4: ROOM_DETECTION<br/>Find ALL rooms"]
        D5["Pass 5: ROOM_FIXTURES<br/>Count lights, sockets per room"]
        D6["Pass 6: CABLE_ROUTES<br/>Site cable runs"]

        D1 --> D2 --> D3 --> D4 --> D5 --> D6
    end

    subgraph TIER_PROMPTS["TIER PROMPTS"]
        TP1["residential_prompts.py<br/>Room-by-room schema"]
        TP2["commercial_prompts.py<br/>Area-based W/m2"]
        TP3["sld_prompt.py<br/>Circuit schedules"]
        TP4["lighting_layout.py<br/>Fixture counting"]
        TP5["legend_prompt.py<br/>Symbol definitions"]
    end

    subgraph REVIEW["STAGE 4: REVIEW<br/>(Human-in-the-Loop)"]
        RV1["Streamlit UI"]
        RV2["Contractor validates"]
        RV3["Edit corrections"]
        RV4["CorrectionLog"]
        RV1 --> RV2 --> RV3 --> RV4
    end

    subgraph VALIDATE["STAGE 5: VALIDATE<br/>(Python Code - FREE)"]
        V1["SANS 10142-1 Rules"]
        V2["Max 10 lights/circuit"]
        V3["Max 10 sockets/circuit"]
        V4["ELCB 30mA mandatory"]
        V5["Dedicated circuits"]
        V6["Auto-corrections"]
        V1 --> V2 & V3 & V4 & V5
        V2 & V3 & V4 & V5 --> V6
    end

    subgraph CONSTANTS["CODE: constants.py<br/>(1650 lines SA Database)"]
        CO1["ELECTRICAL_CABLES"]
        CO2["ELECTRICAL_DB"]
        CO3["ELECTRICAL_LIGHTS"]
        CO4["LABOUR_RATES"]
        CO5["COC_FEES"]
    end

    subgraph CALCULATIONS["CODE: calculations.py"]
        CA1["calculate_load()"]
        CA2["calculate_admd()"]
        CA3["voltage_drop()"]
        CA4["cable_size()"]
    end

    subgraph PRICE["STAGE 6: PRICE<br/>(Python Code - FREE)"]
        P1["14-Section BQ<br/>Categorization"]
        P2["Item Generation"]
        P3["Dual BQ Output"]
        P4["Quantity-Only BQ<br/>(Primary)"]
        P5["Estimated BQ<br/>(Reference)"]
        P1 --> P2 --> P3
        P3 --> P4
        P3 --> P5
    end

    subgraph OUTPUT["STAGE 7: OUTPUT"]
        O1["Excel BOQ<br/>(openpyxl)<br/>4 Sheets"]
        O2["PDF Quotation<br/>(fpdf2)<br/>Professional"]
        O3["JSON Results"]
    end

    subgraph EXCEL["Excel BOQ Sheets"]
        E1["Sheet 1: Cover"]
        E2["Sheet 2: BOQ"]
        E3["Sheet 3: Summary"]
        E4["Sheet 4: Discrepancies"]
    end

    %% Flow connections
    PDF1 & PDF2 & PDF3 & PDF4 & IMG --> INGEST
    INGEST --> CLASSIFY
    PC -.->|"feeds"| CLASSIFY
    CLASSIFY --> DISCOVER
    SYSTEM_PROMPT -.->|"domain knowledge"| DISCOVER
    TIER_PROMPTS -.->|"extraction schemas"| DISCOVER
    DISCOVER --> REVIEW
    REVIEW --> VALIDATE
    VALIDATE --> PRICE
    CONSTANTS -.->|"material prices"| PRICE
    CALCULATIONS -.->|"formulas"| PRICE
    PRICE --> OUTPUT
    O1 --> EXCEL

    %% Styling
    style INPUT fill:#1a1a2e,stroke:#00D4FF,color:#fff
    style INGEST fill:#16213e,stroke:#27ae60,color:#fff
    style PROMPTS_CLASSIFY fill:#8e44ad,stroke:#9b59b6,color:#fff
    style CLASSIFY fill:#0f3460,stroke:#3498db,color:#fff
    style SYSTEM_PROMPT fill:#9b59b6,stroke:#8e44ad,color:#fff
    style TIER_PROMPTS fill:#8e44ad,stroke:#9b59b6,color:#fff
    style DISCOVER fill:#1a1a2e,stroke:#9b59b6,color:#fff
    style REVIEW fill:#c0392b,stroke:#e74c3c,color:#fff
    style VALIDATE fill:#16213e,stroke:#27ae60,color:#fff
    style CONSTANTS fill:#e67e22,stroke:#f39c12,color:#000
    style CALCULATIONS fill:#d35400,stroke:#e67e22,color:#fff
    style PRICE fill:#0f3460,stroke:#f39c12,color:#fff
    style OUTPUT fill:#1a1a2e,stroke:#00D4FF,color:#fff
    style EXCEL fill:#16213e,stroke:#00D4FF,color:#fff
